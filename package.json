{
  "name": "kolshek",
  "version": "0.1.4",
  "description": "CLI tool for tracking finances from Israeli banks and credit cards (כל שקל)",
  "type": "module",
  "bin": {
    "kolshek": "./src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prebuild": "bun scripts/generate-plugin-embed.ts",
    "build": "bun build ./src/cli/index.ts --compile --outfile dist/kolshek",
    "build:windows-x64": "bun build ./src/cli/index.ts --compile --target=bun-windows-x64 --outfile dist/kolshek-windows-x64.exe",
    "build:linux-x64": "bun build ./src/cli/index.ts --compile --target=bun-linux-x64 --outfile dist/kolshek-linux-x64",
    "build:linux-arm64": "bun build ./src/cli/index.ts --compile --target=bun-linux-arm64 --outfile dist/kolshek-linux-arm64",
    "build:macos-x64": "bun build ./src/cli/index.ts --compile --target=bun-darwin-x64 --outfile dist/kolshek-macos-x64",
    "build:macos-arm64": "bun build ./src/cli/index.ts --compile --target=bun-darwin-arm64 --outfile dist/kolshek-macos-arm64"
  },
  "keywords": [
    "israel",
    "finance",
    "banking",
    "credit-card",
    "cli",
    "scraper"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.0",
    "commander": "^13.0.0",
    "date-fns": "^4.0.0",
    "env-paths": "^3.0.0",
    "israeli-bank-scrapers-core": "^6.7.0",
    "ora": "^8.0.0",
    "puppeteer-core": "^24.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "smol-toml": "^1.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "better-sqlite3": "^12.6.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
